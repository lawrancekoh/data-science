      "source": [
        "## 4. TextRank Extractive Summarization\n",
        "\n",
        "Implement the TextRank algorithm, which treats sentences as nodes in a graph and uses PageRank to identify important sentences."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "metadata": {},
      "outputs": [],
      "source": [
        "class TextRankSummarizer:\n",
        "    \"\"\"TextRank-based extractive summarizer.\"\"\"\n",
        "\n",
        "    def __init__(self, similarity_threshold=0.1, max_iter=100, damping=0.85):\n",
        "        self.threshold = similarity_threshold\n",
        "        self.max_iter = max_iter\n",
        "        self.damping = damping\n",
        "        self.preprocessor = TextPreprocessor()\n",
        "\n",
        "    def _build_similarity_matrix(self, sentences, processed):\n",
        "        \"\"\"Create similarity matrix using cosine similarity.\"\"\"\n",
        "        n = len(sentences)\n",
        "        matrix = np.zeros((n, n))\n",
        "\n",
        "        for i in range(n):\n",
        "            for j in range(n):\n",
        "                if i != j:\n",
        "                    sim = self._cosine_similarity(processed[i], processed[j])\n",
        "                    matrix[i, j] = sim\n",
        "\n",
        "        # Normalize the matrix\n",
        "        row_sums = matrix.sum(axis=1)\n",
        "        matrix = matrix / row_sums[:, np.newaxis]\n",
        "        return matrix\n",
        "\n",
        "    def _cosine_similarity(self, vec1, vec2):\n",
        "        \"\"\"Calculate cosine similarity between two sentence vectors.\"\"\"\n",
        "        all_words = set(vec1 + vec2)\n",
        "        vector1 = [vec1.count(word) for word in all_words]\n",
        "        vector2 = [vec2.count(word) for word in all_words]\n",
        "\n",
        "        dot_product = sum(p*q for p, q in zip(vector1, vector2))\n",
        "        magnitude1 = sum(p**2 for p in vector1) ** 0.5\n",
        "        magnitude2 = sum(p**2 for p in vector2) ** 0.5\n",
        "\n",
        "        if magnitude1 == 0 or magnitude2 == 0:\n",
        "            return 0\n",
        "        return dot_product / (magnitude1 * magnitude2)\n",
        "\n",
        "    def _page_rank(self, similarity_matrix):\n",
        "        \"\"\"Compute PageRank scores for sentences.\"\"\"\n",
        "        n = similarity_matrix.shape[0]\n",
        "        transpose_matrix = similarity_matrix.T\n",
        "\n",
        "        # Initialize scores equally\n",
        "        scores = np.full(n, 1/n)\n",
        "\n",
        "        for _ in range(self.max_iter):\n",
        "            prev_scores = scores\n",
        "            scores = (1 - self.damping) + self.damping * np.dot(transpose_matrix, scores)\n",
        "\n",
        "            # Check for convergence\n",
        "            if np.sum(np.fabs(scores - prev_scores)) == 0:\n",
        "                break\n",
        "\n",
        "        return scores\n",
        "\n",
        "    def summarize(self, text, num_sentences=3):\n",
        "        \"\"\"Generate summary using TextRank algorithm.\"\"\"\n",
        "        sentences, processed = self.preprocessor.preprocess_document(text)\n",
        "\n",
        "        if len(sentences) <= num_sentences:\n",
        "            return sentences\n",
        "\n",
        "        # Build similarity matrix and compute PageRank\n",
        "        similarity_matrix = self._build_similarity_matrix(sentences, processed)\n",
        "        scores = self._page_rank(similarity_matrix)\n",
        "\n",
        "        # Select top-k sentences\n",
        "        top_k_indices = np.argsort(scores)[-num_sentences:][::-1]\n",
        "        top_k_sentences = [sentences[i] for i in top_k_indices]\n",
        "\n",
        "        return top_k_sentences"
      ]
    },
