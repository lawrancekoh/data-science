        "## 3. Enhanced Preprocessing Pipeline\n",
        "\n",
        "Clean and prepare text for summarization with advanced preprocessing steps."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 4,
      "metadata": {},
      "outputs": [],
      "source": [
        "class TextPreprocessor:\n",
        "    \"\"\"Enhanced text preprocessing for summarization.\"\"\"\n",
        "\n",
        "    def __init__(self):\n",
        "        self.stop_words = set(stopwords.words('english'))\n",
        "        self.lemmatizer = WordNetLemmatizer()\n",
        "\n",
        "    def clean_text(self, text):\n",
        "        \"\"\"Remove special characters, HTML entities, and normalize whitespace.\"\"\"\n",
        "        # Remove citation brackets and numbers\n",
        "        text = re.sub(r'\\[[0-9]*\\]', ' ', text)\n",
        "        # Remove extra whitespace\n",
        "        text = re.sub(r'\\s+', ' ', text)\n",
        "        # Remove special characters and digits (keep basic punctuation)\n",
        "        text = re.sub(r'[^a-zA-Z\\s]', '', text)\n",
        "        return text.strip()\n",
        "\n",
        "    def preprocess_sentence(self, sentence):\n",
        "        \"\"\"Tokenize, remove stop words, and lemmatize a sentence.\"\"\"\n",
        "        words = word_tokenize(sentence.lower())\n",
        "        filtered_words = [\n",
        "            self.lemmatizer.lemmatize(word) for word in words\n",
        "            if word not in self.stop_words and len(word) > 1\n",
        "        ]\n",
        "        return filtered_words\n",
        "\n",
        "    def preprocess_document(self, document):\n",
        "        \"\"\"Full preprocessing pipeline for a document.\"\"\"\n",
        "        cleaned = self.clean_text(document)\n",
        "        sentences = sent_tokenize(cleaned)\n",
        "        processed_sentences = [self.preprocess_sentence(s) for s in sentences]\n",
        "        return sentences, processed_sentences"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 5,
      "metadata": {},
