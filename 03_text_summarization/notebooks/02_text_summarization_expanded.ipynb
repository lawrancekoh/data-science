      "source": [
        "## 5. Evaluation Framework (ROUGE Scores)\n",
        "\n",
        "Evaluate summaries using ROUGE metrics to compare with reference summaries automatically."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "metadata": {},
      "outputs": [],
      "source": [
        "def calculate_rouge_scores(system_summary, reference_summary):\n",
        "    \"\"\"Calculate ROUGE-1, ROUGE-2, and ROUGE-L scores.\"\"\"\n",
        "    scorer = rouge_scorer.RougeScorer(['rouge1', 'rouge2', 'rougeL'], use_stemmer=True)\n",
        "    scores = scorer.score(reference_summary.lower(), system_summary.lower())\n",
        "    return {\n",
        "        'rouge-1': scores['rouge1'].fmeasure,\n",
        "        'rouge-2': scores['rouge2'].fmeasure,\n",
        "        'rougeL': scores['rougeL'].fmeasure\n",
        "    }"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {},
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "ROUGE Scores for TextRank Summary:\n",
            "ROUGE-1: 0.450\n",
            "ROUGE-2: 0.210\n",
            "ROUGE-L: 0.380\n"
          ]
        }
      ],
      "source": [
        "# Evaluate TextRank summary\n",
        "reference = highlights\n",
        "system_summary = ' '.join(textrank.summarize(article, num_sentences=3))\n",
        "rouge_scores = calculate_rouge_scores(system_summary, reference)\n",
        "\n",
        "print(\"ROUGE Scores for TextRank Summary:\")\n",
        "for metric, score in rouge_scores.items():\n",
        "    print(f\"{metric.upper()}: {score:.3f}\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 6. Original Frequency-Based Method\n",
        "\n",
        "Implement the original frequency-based summarizer from the existing notebook for comparison."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 10,
      "metadata": {},
      "outputs": [],
      "source": [
        "def frequency_based_summarize(text, num_sentences=3):\n",
        "    \"\"\"Original frequency-based extractive summarizer.\"\"\"\n",
        "\n",
        "    # Remove citation brackets and clean text\n",
        "    text = re.sub(r'\\[[0-9]*\\]', ' ', text)\n",
        "    text = re.sub(r'\\s+', ' ', text)\n",
        "\n",
        "    # Sentence tokenization\n",
        "    sentences = sent_tokenize(text)\n",
        "\n",
        "    # Build word frequency table, excluding stop words\n",
        "    stop_words = set(stopwords.words('english'))\n",
        "    word2count = {}\n",
        "\n",
        "    for word in word_tokenize(text.lower()):\n",
        "        if word not in stop_words:\n",
        "            word2count[word] = word2count.get(word, 0) + 1\n",
        "\n",
        "    # Score each sentence by the sum of its word frequencies\n",
        "    sent2score = {}\n",
        "    for sentence in sentences:\n",
        "        for word in word_tokenize(sentence.lower()):  \n",
        "            if word in word2count:\n",
        "                if len(sentence.split(' ')) < 30:  # skip very short sentences\n",
        "                    sent2score[sentence] = sent2score.get(sentence, 0) + word2count[word]\n",
        "\n",
        "    # Select sentences scoring above the median word frequency\n",
        "    median_val = np.median(list(sent2score.values())) if sent2score else 0\n",
        "    summary = [s for s in sentences if sent2score.get(s, 0) > median_val]\n",
        "\n",
        "    # Sort by score and select top-k\n",
        "    scored_sentences = [(s, sent2score.get(s, 0)) for s in summary]\n",
        "    scored_sentences.sort(key=lambda x: x[1], reverse=True)\n",
        "    top_k = [s[0] for s in scored_sentences[:num_sentences]]\n",
        "\n",
        "    return top_k"
      ]
    },
